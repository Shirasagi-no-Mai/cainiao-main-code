                        )
                    except Exception:
                        pass

        except Exception as e:
            print(f"[渠道提取异常] {e}")

        # 把未匹配的单元格内容放进结果（后面写 Excel 时取）
        result["未识别渠道"] = " | ".join(unmatched_cells) if unmatched_cells else "N/A"
        return result

