        if s in ["N", "N/A", "None", ""]: return None
        try:
            now = datetime.now()
            if re.match(r'^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}:\d{2}$', s):
                return s
            match_ampm = re.match(r'^(\d{1,2})/(\d{1,2})/(\d{4})\s+(\d{1,2}:\d{2}:\d{2})\s+([AP]M)$', s)
            if match_ampm:
