                return dt.strftime("%Y-%m-%d %H:%M:%S")
            match_core = re.search(r'(\d{1,2})/(\d{1,2})\s+(\d{1,2}:\d{2})', s)
            if match_core:
                m, d, t = match_core.groups()
                m, d = int(m), int(d)
                for year in [now.year, now.year - 1]:
                    try:
                        dt = datetime.strptime(f"{year}/{m}/{d} {t}", "%Y/%m/%d %H:%M")
                        if abs((dt - now).days) <= 3:
                            return dt.strftime("%Y-%m-%d %H:%M:%S")
                    except:
                        continue
                return f"{now.year}-{m:02d}-{d:02d} {t}:00"
            return None
