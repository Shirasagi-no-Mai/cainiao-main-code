                # 写入结果到 E, F, G 列
                df.at[index, 4] = number  # E 列：单号中 - 后的数字
                df.at[index, 5] = sum_duty if not pd.isna(sum_duty) else "N/A"  # F 列：Duty 列和
                df.at[index, 6] = sum_user_fee if not pd.isna(sum_user_fee) else "N/A"  # G 列：User Fee 列和
