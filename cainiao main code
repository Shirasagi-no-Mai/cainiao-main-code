    # 统一渠道顺序与映射（修正：将 DHLe 改为 DHL，统一标准）
    channel_order = [
        "COE/UP", "DHL", "SPX", "ACI", "USPS",  "FEDEX", "GOFO", "TOO","IB", "UNIUNI", "OC UNIUNI", "YW EXP"
    ]

    exact_match_to_std = {
        "GOFO": "GOFO",
        "TOOEXPRESS": "TOO",
        "TOOEXPRESS-DF": "TOO",
        "UNIUNI": "UNIUNI",
        "OC-UNI": "OC UNIUNI",
        "DHL": "DHL",
        "IB": "IB",
        "SPX": "SPX",
        "ACI": "ACI",
        "FEDEX GROUND": "FEDEX",
        "USPS-GA": "USPS",
        "COE": "COE/UP",
        "YW EXPRESS": "YW EXP",
    }

    def extract_flight_info(response_dict):
        try:
            html_body = response_dict["data"]["body"]
        except:
            return {}

        soup = BeautifulSoup(html_body, "html.parser")
        num_re = re.compile(r'[\d,]+\.?\d*')
        eta_re = re.compile(r'(\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2})')

        result = {
            "MAWB": "N/A", "ETA": "N/A", "NUMBER OF CTN": "N/A",
            "GROSS WEIGHT": "N/A", "QUANTITY OF PARCELS": "N/A", "未识别渠道": "N/A",
        }

        for ch in channel_order:
            result[f"{ch}_CTN"] = "N/A"
            result[f"{ch}_PARCELS"] = "N/A"
            result[f"{ch}_WEIGHT"] = "N/A"

        # 1. 提取主表
        main_table = soup.find("table", align="center")
        if main_table:
            for row in main_table.find_all("tr"):
                tds = row.find_all("td")
                if len(tds) != 2: continue
                key = tds[0].get_text(strip=True)
                raw_value = tds[1].get_text(strip=True)
                if "ETA" in key:
                    m = eta_re.search(raw_value)
                    result["ETA"] = m.group(1) if m else "N/A"
                else:
                    num_match = num_re.search(raw_value.replace(',', ''))
                    value = num_match.group(0) if num_match else "N/A"
                    if "MAWB No." in key:
                        result["MAWB"] = raw_value
                    elif "Number of CTN" in key:
                        result["NUMBER OF CTN"] = value
                    elif "Gross Weight" in key:
                        result["GROSS WEIGHT"] = value
                    elif "Quantity of parcels" in key:
                        result["QUANTITY OF PARCELS"] = value

        # 2. 提取渠道明细表
        unmatched_cells = []
        tables = soup.find_all("table")
        for table in tables:
            rows = table.find_all("tr")
            for row in rows:
                tds = row.find_all("td")
                if len(tds) < 4: continue

                # 修正：处理不可见空格 \xa0 导致的匹配失败
                channel_raw = tds[0].get_text().replace('\xa0', ' ').strip()
                if any(k in channel_raw for k in ["MAWB", "CTN", "parcels", "Weight", "Channel", "Last mile"]):
                    continue

                std = exact_match_to_std.get(channel_raw)
                if not std:
                    if channel_raw: unmatched_cells.append(channel_raw)
                    continue

                # 提取数字并累加
                def get_clean_num(td):
                    m = num_re.search(td.get_text(strip=True).replace(',', ''))
                    return m.group(0) if m else "0"

                ctn = get_clean_num(tds[1])
                parcels = get_clean_num(tds[2])
                weight = get_clean_num(tds[3])

                for k, v in [(f"{std}_CTN", ctn), (f"{std}_PARCELS", parcels), (f"{std}_WEIGHT", weight)]:
                    old_v = result.get(k, "N/A")
                    result[k] = str(float(v) + (float(old_v) if old_v != "N/A" else 0))

        result["未识别渠道"] = " | ".join(list(set(unmatched_cells))) if unmatched_cells else "N/A"
        return result

    # 主循环逻辑
    raw_query = get_mail_list()
    email_id_list = extract_mail_ids(raw_query)
    results = []
    processed_count = 0

    for email_id in email_id_list[:int(limit_param)]:
        result = get_mail_content(email_id)
        if result and result.get("status") in [0, 6]:
            info = extract_flight_info(result)
