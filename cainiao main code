def encrypt_code(code: str) -> bytes:
    """加密代码（zlib+base64）"""
    try:
        return base64.b64encode(zlib.compress(code.encode('utf-8')))
    except Exception as e:
        print(f"加密失败: {e}")
        return None


def decrypt_code(data: bytes) -> str:
    """解密代码"""
    try:
        return zlib.decompress(base64.b64decode(data)).decode('utf-8')
    except Exception as e:
        print(f"解密失败: {e}")
        return None


def fetch_python_code():
    """从 GitHub 或本地获取 Python 代码（加密存储）"""
    # 优先本地加密文件

    # 网络请求（带重试）
    session = requests.Session()
    retries = Retry(total=3, backoff_factor=1, status_forcelist=[429, 500, 502, 503, 504])
    session.mount("https://", HTTPAdapter(max_retries=retries))

    all_urls = [CONFIG_URL] + ALTERNATIVE_URLS
    for url in all_urls:
        try:
            print(f"尝试 URL: {url}")
            headers = {}  # 私有仓库用: {'Authorization': 'token ghp_你的TOKEN'}
            response = session.get(url, headers=headers, timeout=10)
            print(f"  状态码: {response.status_code}")
            if response.status_code == 200:
                code = response.text.strip()
                if not code:
                    print("  下载为空，跳过")
                    continue
                print(f"  ✓ 下载成功，预览: {code[:100]}...")
                print("  逐行内容（前5行）：")
                for i, line in enumerate(code.splitlines()[:5], 1):
                    print(f"    Line {i}: {line}")
                # 加密保存到临时目录

                return code
            else:
                print(f"  失败: {response.status_code} - {response.reason}")
        except (ConnectionError, Timeout, RequestException) as e:
            print(f"  网络错误: {e}")
        except Exception as e:
            print(f"  其他错误: {e}")

    print("✗ 所有 URL 失败！请检查仓库/文件，或用本地文件。")
    return None


def main():
    """主函数：运行远程或本地代码"""
    code_text = fetch_python_code()
    if not code_text:
        print("✗ 无法获取代码，程序退出")
        sys.exit(1)

    try:
        print("开始执行远程代码...")
        exec(code_text, {})
        print("✓ 远程代码执行成功")
    except SyntaxError as e:
        print(f"语法错误: {e}")
        print("检查远程代码是否有效 Python")
        sys.exit(1)
    except ImportError as e:
        print(f"缺少模块: {e}")
        print("确保本地安装 openpyxl, selenium, pandas, msoffcrypto 等")
        sys.exit(1)
    except Exception as e:
        print(f"执行失败: {e}")
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
