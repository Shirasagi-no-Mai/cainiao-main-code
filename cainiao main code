            "Content-Type": "application/json",
            "X-Xsrf-Token": token,
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        }

        def post_with_retry(url, payload, retries=3):
            for i in range(retries):
                try:
                    response = requests.post(url, headers=headers, cookies=cookies, json=payload, timeout=20)
                    if response.status_code == 200:
                        return response.json()
                    else:
                        update_output_text(output_text, f"  -> [Retry {i + 1}] 接口返回状态码: {response.status_code}\n")
                except Exception as e:
                    update_output_text(output_text, f"  -> [Retry {i + 1}] 请求异常: {e}\n")
                if i < retries - 1:
                    time.sleep(1.5)
            return {}

        update_output_text(output_text, f"正在查询 AWB: {awb} ...\n")
        r1_data = post_with_retry("https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/manifest/queryPage",
                                  {"domain": "USA", "linehualCode": awb})

        table = r1_data.get('data', {}).get('tableData', [])
        if not table:
            update_output_text(output_text, f"  -> 未找到 {awb} 的 Manifest 数据\n")
            return res

        res["mfcode"] = table[0].get('mfCode', 'N/A')
        time.sleep(0.3)

        r2_data = post_with_retry("https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/log/pageQuery",
                                  {
                                      "domain": "USA",
                                      "businessCode": res["mfcode"],
                                      "businessType": "MANIFEST",
                                      "pageNo": 1,
                                      "pageSize": 100
                                  })

        logs = r2_data.get('data', {}).get('tableData', [])
        for log in logs:
            code, ts = log.get('code'), log.get('operateTime')
            content = str(log.get('content', ''))
            if ts:
                time_str = datetime.fromtimestamp(ts / 1000).strftime('%Y-%m-%d %H:%M:%S')
                if code == 'INBOUND' and not res["in_t"]: res["in_t"] = time_str
                if code == 'OUTBOUND' and not res["out_t"]: res["out_t"] = time_str
                if code in ['PARTIAL_HANDOVER', 'HANDOVER'] and not res["han_t"]: res["han_t"] = time_str
            if 'UNIUNI末端配送' in content: res["uni_up"] = "Yes"
            if '美国统包标准配送资源' in content: res["coe_up"] = "Yes"
            if '美国USPS直连末端配送' in content: res["usps_up"] = "Yes"
            if 'MAERSK-末端配送' in content: res["maersk_up"] = "Yes"
            if 'SpeedX配送' in content: res["speedx_up"] = "Yes"
            if 'GOFO配送' in content: res["gofo_up"] = "Yes" # 确认 API 返回的 GOFO 关键字

        time.sleep(0.3)
        r3_data = post_with_retry("https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/log/timeline",
                                  {"domain": "USA", "businessCode": res["mfcode"], "businessType": "MANIFEST"})

        for item in r3_data.get('data', []):
            if item.get('name') == 'INBOUND':
                res["in_s"] = 'Y' if item.get('status') == 'finish' else 'N'
            if item.get('name') == 'OUTBOUND':
                res["out_s"] = 'Y' if item.get('status') == 'finish' else 'N'
        return res

    # ==================== 主逻辑 (完全照搬) ====================
    update_output_text(output_text, "正在加载 AGS 数据...\n")
    ags_info = {}
    if os.path.exists(file_path_ags):
        wb_ags = openpyxl.load_workbook(file_path_ags, data_only=True)
        ws_ags = wb_ags.active
        # 1. 强力清洗：把换行(\n)、回车(\r)和空格全删掉，统统变大写
        headers = []
        for cell in ws_ags[1]:
            if cell.value:
                clean_h = str(cell.value).replace("\n", "").replace("\r", "").replace(" ", "").upper()
                headers.append(clean_h)
            else:
                headers.append("")

        # 2. 这里的 Key 也要对应删掉空格和换行
        mapping = {
            "UNI": "LASTMILESUNI(2070)",
            "COE": "LASTMILESCOE(2070)",
            "USPS": "LASTMILESUSPS(2070)",
            "MAERSK": "LASTMILESMAERSK(2070)",
            "SPEEDX": "LASTMILESSPEEDX(2070)",
            "GOFO": "LASTMILESGOFO(2070)",  # 新增
            "IN_BACKUP": "CARGOINTIME2020",
            "OUT_BACKUP": "SORTINGTIME(2060)"
        }
        # 3. 使用 in 来进行模糊匹配，更稳健
        idx_map = {}
        for k, v in mapping.items():
            for i, h in enumerate(headers):
                if v in h:  # 只要包含关键字就匹配
                    idx_map[k] = i + 1
                    break
        for r in range(2, ws_ags.max_row + 1):
            awb_val = str(ws_ags.cell(row=r, column=3).value or "").replace(" ", "")
            if awb_val:
                ags_info[awb_val] = {k: convert_to_standard_time(ws_ags.cell(row=r, column=v).value) for k, v in
                                     idx_map.items()}



    wb = openpyxl.load_workbook(file_path_bbc)
    ws = wb.active

    update_output_text(output_text, f"正在根据模式 {mode} 清理历史数据与格式...\n")
    for r in range(2, ws.max_row + 1):
        # 如果 mode 不是 1，通常只清理时间列。现在时间列从 12 开始。
        start_col = 2 if mode == '1' else 12
        for c in range(start_col, 22):  # 明确范围到 21
            cell = ws.cell(row=r, column=c)
            cell.value = None
            cell.fill = NO_FILL

    lax_now = get_lax_now()

    for row in range(2, ws.max_row + 1):
        awb = str(ws.cell(row=row, column=1).value or "").strip()
        if not awb: continue

        for col_reset in range(2, 22):  # 清理到 21 列
            ws.cell(row=row, column=col_reset).fill = NO_FILL
        ws.cell(row=row, column=20).value = ""  # 清理派送时间
        ws.cell(row=row, column=21).value = ""  # 清理备注

        update_output_text(output_text, f"正在处理: {awb}\n")

        cur_in_s = str(ws.cell(row=row, column=4).value).strip().upper()
        cur_out_s = str(ws.cell(row=row, column=5).value).strip().upper()
        cur_in_t = str(ws.cell(row=row, column=12).value).strip().upper()  # 12 是 IN Time
        cur_out_t = str(ws.cell(row=row, column=13).value).strip().upper()  # 13 是 OUT Time

        api_in_t = None
        api_out_t = None

        if mode == '1':
            api = fetch_api_data(awb)
            ws.cell(row=row, column=2).value = api["mfcode"]
            ws.cell(row=row, column=3).value = awb
            ws.cell(row=row, column=4).value = api["in_s"]
            ws.cell(row=row, column=5).value = api["out_s"]
            ws.cell(row=row, column=6).value = api["uni_up"]
            ws.cell(row=row, column=7).value = api["coe_up"]
            ws.cell(row=row, column=8).value = api["usps_up"]
            ws.cell(row=row, column=9).value = api["maersk_up"]
            ws.cell(row=row, column=10).value = api["speedx_up"]
            ws.cell(row=row, column=11).value = api["gofo_up"]  # 新增第 11 列

            api_in_t = api["in_t"]
            api_out_t = api["out_t"]

        ags = ags_info.get(awb, {})

        if not (cur_in_s == 'Y' or cur_in_t in ['#N/A']):
            val_in = api_in_t if (mode == '1' and api_in_t) else ags.get("IN_BACKUP")
            if val_in:
                ws.cell(row=row, column=12).value = val_in  # 12 是 IN Time
            elif not ws.cell(row=row, column=12).value:
                ws.cell(row=row, column=12).value = "N"

        if not (cur_out_s == 'Y' or cur_out_t in ['#N/A']):
            val_out = api_out_t if (mode == '1' and api_out_t) else ags.get("OUT_BACKUP")
            if val_out:
                ws.cell(row=row, column=13).value = val_out  # 13 是 OUT Time
            elif not ws.cell(row=row, column=13).value:
                ws.cell(row=row, column=13).value = "N"

        chan_tasks = [
            (14, "UNI"), (15, "COE"), (16, "USPS"),
            (17, "MAERSK"), (18, "SPEEDX"), (19, "GOFO")  # GOFO 在 19 列
        ]

        for t_col, ags_key in chan_tasks:
            ags_time = ags.get(ags_key)
            if ags_time and ags_time not in ["N", "N/A", ""]:
                ws.cell(row=row, column=t_col).value = ags_time

        status_cols = [4, 5, 6, 7, 8, 9, 10, 11]  # 增加 11
        time_cols = [12, 13, 14, 15, 16, 17, 18, 19]  # 整体偏移
        for s_col, t_col in zip(status_cols, time_cols):
            s_val = str(ws.cell(row=row, column=s_col).value).strip().upper()
            t_cell = ws.cell(row=row, column=t_col)
            t_val = str(t_cell.value).strip().upper()
            if t_val == "#N/A":
                t_cell.fill = GREEN_FILL
            elif s_val in ['Y', 'YES']:
                t_cell.fill = GREEN_FILL
            elif s_val in ['N', 'NO'] and t_val not in ['', 'N', 'NONE', 'N/A']:
                t_cell.fill = YELLOW_FILL

        in_status = str(ws.cell(row=row, column=4).value).strip().upper()
        out_status = str(ws.cell(row=row, column=5).value).strip().upper()
        for col in range(12, 20):
            cell = ws.cell(row=row, column=col)
            if cell.fill == GREEN_FILL: continue
            if col == 12 and in_status == 'Y': continue  # 入库时间
            if col == 13 and out_status == 'Y': continue  # 出库时间
            dt = parse_to_dt(cell.value)
            if dt and dt < lax_now - timedelta(hours=24):
                cell.fill = RED_FILL

        t_in = parse_to_dt(ws.cell(row=row, column=12).value)  # 12
        t_out = parse_to_dt(ws.cell(row=row, column=13).value)  # 13
        inverted = False
        if t_in and t_out and t_out < t_in:
            inverted = True
        if t_out:
            for col in range(14, 20):
                t_c = parse_to_dt(ws.cell(row=row, column=col).value)
                if t_c and t_c < t_out:
                    inverted = True
                    break
        if inverted:
            ws.cell(row=row, column=21).value = "时间倒挂"  # 备注移到 21
            ws.cell(row=row, column=21).fill = RED_FILL

    update_output_text(output_text, "\n>>> 正在计算派送时间 (第20列)...\n")
    for r in range(2, ws.max_row + 1):
        channel_times = []
        for col in [14, 15, 16, 17, 18, 19]:  # 涵盖所有渠道：14(UNI) 到 19(GOFO)
            t_val = parse_to_dt(ws.cell(row=r, column=col).value)
            if t_val:
                channel_times.append(t_val)
        if channel_times:
            ws.cell(row=r, column=20).value = max(channel_times).strftime('%Y-%m-%d %H:%M:%S')  # 写入 20 列

    wb.save(file_path_bbc)
    update_output_text(output_text, "更新完成！\n")


def wipe_off_AE(account, password, output_text, folder_id_param, limit_param):
    # 1. 定义分销商映射关系：{邮件中的显示名字: [Excel重量列名, Excel数量列名]}
    DISTRIBUTORS = {
        "MAERSK-末端配送": ["MAERSK-末端配送_Gross_Weight", "MAERSK-末端配送_Qty"],
        "美国统包标准配送资源": ["美国统包标准配送资源_Gross_Weight", "美国统包标准配送资源_Qty"],
        "美国USPS直连末端配送": ["美国USPS直连末端配送_Gross_Weight", "美国USPS直连末端配送_Qty"],
        "SpeedX配送": ["SpeedX配送_Gross_Weight", "SpeedX配送_Qty"],
        "UNIUNI末端配送": ["UNIUNI末端配送_Gross_Weight", "UNIUNI末端配送_Qty"]
    }
    MAIL_LIST_LIMIT_PER_QUERY = 100

    # -------------------- 路径和文件检查 --------------------
    user_home = os.path.expanduser("~")
    possible_paths = [
        os.path.join(user_home, "Desktop"),
        os.path.join(user_home, "桌面"),
        os.path.join(user_home, "OneDrive", "Desktop"),
        os.path.join(user_home, "OneDrive", "桌面")
    ]
    desktop_path = next((path for path in possible_paths if os.path.exists(path)), None)

    if not desktop_path:
        update_output_text(output_text, "❌ 未找到桌面路径\n")
        return

    file_path = os.path.join(desktop_path, "实报实销AE.xlsx")

    # -------------------- 内部函数定义 --------------------

    def read_cookies_from_txt():
        txt_file_path = os.path.join(desktop_path, "emailtoken.txt")
        if not os.path.exists(txt_file_path):
            update_output_text(output_text, "❌ 找不到身份信息文件 emailtoken.txt\n")
            return {}, None
        try:
            with open(txt_file_path, 'r', encoding='utf-8') as f:
                data = json.load(f)
                return data.get("cookies", {}), data.get("xsrf_token", None)
        except Exception as e:
            update_output_text(output_text, f"❌ 读取身份文件异常: {e}\n")
            return {}, None

    def get_mail_list(showFrom, cookies_dict, xsrf_token):
        url = "https://mail.alibaba-inc.com/alimail/ajax/mail/queryMailList.txt"
        payload = {
            "query": f'{{"folderIds":["{str(folder_id_param)}"]}}',
            "showFrom": "1",
            "offset": str(showFrom),
            "length": str(MAIL_LIST_LIMIT_PER_QUERY),
            "_tpl_": "v5ForWebDing",
            "_csrf_token_": xsrf_token
        }
        headers = {
            "Content-Type": "application/x-www-form-urlencoded",
            "Referer": "https://mail.alibaba-inc.com/alimail/entries/v5.1/mail",
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64)"
        }
        session = requests.Session()
        session.cookies.update(cookies_dict)
        try:
            response = session.post(url, headers=headers, data=payload, timeout=15, verify=False)
            text = response.text
            if text.startswith("/**/"):
                match = re.search(r'\((.*)\)', text, re.DOTALL)
                text = match.group(1) if match else text
            return json.loads(text).get("dataList", [])
        except:
            return []

    def get_mail_content(email_id, cookies_dict, xsrf_token):
        url = "https://mail.alibaba-inc.com/alimail/ajax/mail/loadMail.txt"
        payload = {"mailId": email_id, "full": "1", "_tpl_": "v5ForWebDing", "_csrf_token_": xsrf_token}
        headers = {"Content-Type": "application/x-www-form-urlencoded", "User-Agent": "Mozilla/5.0"}
        session = requests.Session()
        session.cookies.update(cookies_dict)
        try:
            response = session.post(url, data=payload, headers=headers, timeout=15, verify=False)
            return response.json()
        except:
            return None

    def extract_flight_info(response_dict):
        try:
            html_body = response_dict["data"]["body"]
        except:
            return {}

        soup = BeautifulSoup(html_body, "html.parser")
        num_re = re.compile(r'[\d,]+\.?\d*')
        result = {"MAWB": "", "HEADER_GROSS_WEIGHT": ""}

        # 初始化字典中的所有分销商列
        for weight_col, qty_col in DISTRIBUTORS.values():
            result[weight_col] = ""
            result[qty_col] = ""

        tables = soup.find_all("table", align="center")
        if not tables: return result

        # 1. 提取主表 MAWB 和总重
        for row in tables[0].find_all("tr"):
            tds = row.find_all("td")
            if len(tds) >= 2:
                k, v = tds[0].get_text(strip=True), tds[1].get_text(strip=True)
                if "MAWB No." in k:
                    result["MAWB"] = v
                elif "Gross Weight" in k:
                    m = num_re.search(v.replace(',', ''))
                    result["HEADER_GROSS_WEIGHT"] = m.group(0) if m else v

        # 2. 提取分销商数据 (核心修正逻辑)
        for table in tables:
            header_td = table.find("td", class_="distributorName")
            if header_td:
                dist_name = header_td.get_text(strip=True)
                if dist_name in DISTRIBUTORS:
                    w_col_name, q_col_name = DISTRIBUTORS[dist_name]

                    for row in table.find_all("tr"):
                        tds = row.find_all("td")
                        if len(tds) >= 2:
                            label = tds[0].get_text(strip=True)
                            raw_val = tds[1].get_text(strip=True).replace(',', '')
                            match = num_re.search(raw_val)

                            if not match: continue
                            val = match.group(0)

                            if "Gross Weight" in label:
                                result[w_col_name] = val

                            # 优先级 1: 匹配 Number of CTN (针对 SpeedX 的 36)
                            elif "Number of CTN" in label:
                                result[q_col_name] = val

                            # 优先级 2: 只有在 CTN 没抓到时，才抓 Quantity (防止被 1408 覆盖)
                            elif ("Quantity" in label or "parcels" in label) and result[q_col_name] == "":
                                result[q_col_name] = val
        return result

    # -------------------- 主逻辑循环 --------------------
    cookies, xsrf = read_cookies_from_txt()
    if not cookies or not xsrf: return

    all_results = []
    processed_count = 0
    num_queries = (limit_param + MAIL_LIST_LIMIT_PER_QUERY - 1) // MAIL_LIST_LIMIT_PER_QUERY

    for i in range(num_queries):
        if processed_count >= limit_param: break
        mails = get_mail_list(i * MAIL_LIST_LIMIT_PER_QUERY, cookies, xsrf)
        if not mails: break

        for m in mails:
            if processed_count >= limit_param: break
            update_output_text(output_text, f"正在处理第 {processed_count + 1} 封邮件...")

            content = get_mail_content(m.get("mailId"), cookies, xsrf)
            if content and content.get("status") in [0, 6]:
                info = extract_flight_info(content)

                # 构造平铺行数据
                flat_row = {
                    "MAWB": info.get("MAWB", ""),
                    "HEADER_GROSS_WEIGHT": info.get("HEADER_GROSS_WEIGHT", "")
                }
                # 遍历映射关系，确保每一列都有值
                for dist_name, cols in DISTRIBUTORS.items():
                    flat_row[cols[0]] = info.get(cols[0], "")  # 重量
                    flat_row[cols[1]] = info.get(cols[1], "")  # 数量

                all_results.append(flat_row)
                processed_count += 1

    # -------------------- 写入 Excel (重排顺序) --------------------
    if all_results:
        # 分离重量列和数量列，以便重排
        w_headers = []
        q_headers = []
        for w, q in DISTRIBUTORS.values():
            w_headers.append(w)
            q_headers.append(q)

        # 最终顺序：基础信息 + 所有重量在前 + 所有数量在后
        final_order = ["MAWB", "HEADER_GROSS_WEIGHT"] + w_headers + q_headers
        df = pd.DataFrame(all_results, columns=final_order)

        try:
            df.to_excel(file_path, index=False)
            update_output_text(output_text, f"\n✅ 成功完成！共处理 {processed_count} 条，数量列已移至末尾。\n")
        except Exception as e:
            update_output_text(output_text, f"❌ 写入 Excel 失败 (请检查是否文件打开中): {e}\n")
    else:
        update_output_text(output_text, "ℹ️ 未提取到有效数据。\n")






























def node_token(account, password, output_text):
    user_home = os.path.expanduser("~")
    possible_paths = [
        os.path.join(user_home, "Desktop"),
        os.path.join(user_home, "桌面"),
        os.path.join(user_home, "OneDrive", "Desktop"),
        os.path.join(user_home, "OneDrive", "桌面")
    ]

    desktop_path = next((path for path in possible_paths if os.path.exists(path)), None)

    if desktop_path:
        txt_file_path = os.path.join(desktop_path, "output.txt")
        if os.path.exists(txt_file_path):
            update_output_text(output_text, "已找到所需的cookie文件，即将继续运行\n\n")
            pass
        else:
            # 创建空的文本文件
            with open(txt_file_path, 'w', encoding='utf-8'):
                update_output_text(output_text, "未找到所需的cookie文件，现已创建，请再次点击运行\n\n")
                pass
            sys.exit()  # 程序立即停止
    else:
        sys.exit()  # 程序立即停止

    chrome_options = webdriver.ChromeOptions()
    chrome_options.add_argument("--start-maximized")  # 启动时最大化
    chrome_options.add_argument("--disable-gpu")  # 解决某些系统的图形渲染问题
    chrome_options.add_argument("--no-sandbox")  # 非root用户需要此参数
    chrome_options.add_argument("--disable-dev-shm-usage")  # 避免某些共享内存问题


    # 启动 Chrome 浏览器
    driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=chrome_options)
    driver.set_window_size(1920, 1080)

    # 通过 JavaScript 强制设置缩放比例
    driver.get("https://www.google.com")
    driver.execute_script("document.body.style.zoom='50%'")
    url = "https://os.gcsp.cainiao-inc.com/USA/manifestlist/manifestlist"
    driver.get(url)
    driver.maximize_window()  # 最大化窗口

    all_tabs = driver.window_handles

    # 遍历所有窗口，关闭不需要的 "data:" 标签页
    for tab in all_tabs:
        driver.switch_to.window(tab)
        if "data:" in driver.current_url:
            driver.close()  # 关闭 "data:" 标签页

    # 重新获取当前所有窗口句柄
    all_tabs = driver.window_handles

    # 如果有剩余窗口，切换到第一个
    if all_tabs:
        driver.switch_to.window(all_tabs[0])

    try:
        # 等待页面加载并检查是否包含 "sign"
        WebDriverWait(driver, 10).until(
            lambda d: "sign" in d.page_source.lower()  # 等待直到页面包含 "sign"
        )
        print("'sign' found in page source. Continuing...")
    except Exception as e:
        print("Timeout or error while waiting for 'sign':", e)
        driver.quit()
        exit()

    username = account  # 替换为实际账号
