def daily_report(output_text):
    user_home = os.path.expanduser("~")
    possible_paths = [
        os.path.join(user_home, "Desktop"),
        os.path.join(user_home, "桌面"),
        os.path.join(user_home, "OneDrive", "Desktop"),
        os.path.join(user_home, "OneDrive", "桌面")
    ]

    desktop_path = next((path for path in possible_paths if os.path.exists(path)), None)

    if desktop_path:
        file_path = os.path.join(desktop_path, "dailyreport.xlsx")
        if not os.path.exists(file_path):
            update_output_text(output_text, "未找到所需的excel已创建，请再次点击开始\n")
            wb = Workbook()
            wb.save(file_path)
            sys.exit()
        else:
            update_output_text(output_text, "已找到所需的excel\n")
    else:
        update_output_text(output_text, "未找到正确的桌面路径\n")
        sys.exit()

    def read_cookies_from_txt():
        try:
            txt_file_path = os.path.join(desktop_path, "output.txt")
            if os.path.exists(txt_file_path):
                with open(txt_file_path, 'r', encoding='utf-8') as txt_file:
                    data = json.load(txt_file)
                    return data.get("cookies", {}), data.get("xsrf_token", None)
            return {}, None
        except Exception as e:
            update_output_text(output_text, f"读取文本文件出错: {e}\n")
            return {}, None

    def get_api_response(awbnum):
        url = "https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/manifest/queryPage"
        cookies, xsrf_token = read_cookies_from_txt()
        if not xsrf_token: return "N/A"

        headers = {
            "Content-Type": "application/json",
            "X-Xsrf-Token": xsrf_token,
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36",
        }

        tomorrow = datetime.now() + timedelta(days=1)
        thirty_days_ago = tomorrow - timedelta(days=30)

        payload = {
            "testMode": "false",
            "domain": "USA",
            "gateCode": "All",
            "linehualCode": awbnum,
            "createTimeBegin": thirty_days_ago.strftime("%d-%m-%Y 00:00:00"),
            "createTimeEnd": tomorrow.strftime("%d-%m-%Y 00:00:00"),
            "createTimeStr": [thirty_days_ago.strftime("%Y-%m-%dT00:00:00.000Z"),
                              tomorrow.strftime("%Y-%m-%dT00:00:00.000Z")]
        }

        try:
            response = requests.post(url, headers=headers, cookies=cookies, json=payload)
            data = response.json()
            return data.get('data', {}).get('tableData', [{}])[0].get('mfCode', 'N/A')
        except:
            return "N/A"

    def get_post_history(mfcode):
        if mfcode == "N/A": return None
        cookies_dict, xsrf_token = read_cookies_from_txt()
        url = "https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/log/pageQuery"
        headers = {"Content-Type": "application/json", "X-Xsrf-Token": xsrf_token, "x-csrf-token": xsrf_token}
        payload = {"testMode": "false", "domain": "USA", "businessCode": mfcode, "businessType": "MANIFEST",
                   "pageNo": 1, "pageSize": 50}
        try:
            response = requests.post(url, headers=headers, cookies=cookies_dict, json=payload)
            return response.json()
        except:
            return None

    def get_all_amount(mfcode):
        if mfcode == "N/A": return None
        cookies_dict, xsrf_token = read_cookies_from_txt()
        url = "https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/parcel/queryPage"
        headers = {"Content-Type": "application/json", "X-Xsrf-Token": xsrf_token}
        payload = {"testMode": "false", "domain": "USA", "mainOrderCode": mfcode, "pageNo": 1, "pageSize": 10}
        try:
            response = requests.post(url, headers=headers, cookies=cookies_dict, json=payload)
            return response.json()
        except:
            return None

    def get_qty_history(mfcode):
        if mfcode == "N/A": return None
        cookies_dict, xsrf_token = read_cookies_from_txt()
        url = "https://os.gcsp.cainiao-inc.com/gcsp-buc/ggg3oc/manifest/getParcelStatusTotal"
        headers = {"Content-Type": "application/json", "X-Xsrf-Token": xsrf_token}
        payload = {"testMode": "false", "domain": "USA", "mainOrderCode": mfcode}
        try:
            response = requests.post(url, headers=headers, cookies=cookies_dict, json=payload)
            return response.json()
        except:
            return None

    def format_ts(ts):
        if not ts: return "N/A"
        return datetime.fromtimestamp(ts / 1000).strftime('%Y/%m/%d %H:%M:%S')

    def generate_manifest_summary(post_history, qty_history, total_amount):
        # 数量统计
        total_count = "N/A"
        try:
            total_count = total_amount['data']['paging']['totalCount']
        except:
            pass

        h_qty, c_qty = 0, 0
        if qty_history and 'data' in qty_history:
            for item in qty_history['data']:
                if item['status'] == 'HANDOVER': h_qty = item['count']
                if item['status'] == 'CC_RELEASE': c_qty = item['count']

        # 时间统计
        in_t, out_t, han_t = "N/A", "N/A", "N/A"

        if post_history and 'data' in post_history:
            print(post_history)
            logs = post_history.get('data', {}).get('tableData', [])
            for log in logs:
                code = log.get('code', '')
                ts = log.get('operateTime')
                if code == 'INBOUND' and in_t == "N/A": in_t = format_ts(ts)
                if code == 'OUTBOUND' and out_t == "N/A": out_t = format_ts(ts)
                # 修改点：必须是 PARTIAL_HANDOVER
                if (code == 'PARTIAL_HANDOVER' or code=='HANDOVER' )and han_t == "N/A": han_t = format_ts(ts)

        return [total_count, h_qty, c_qty, in_t, out_t, han_t]

    def main_function():
        try:
            wb = openpyxl.load_workbook(file_path)
            ws = wb.active

            # 强制重写/检查表头 (A到I)
            headers = ['原始awb', 'MFCODE', 'awb', '总数量', '派送数量', '放行数量', 'INBOUND时间', 'OUTBOUND时间',
                       '最新HANDOVER时间']
            if ws['A1'].value != '原始awb':
                ws.insert_rows(1)
            for i, h in enumerate(headers, 1):
                ws.cell(row=1, column=i).value = h

            # 获取数据行
            rows = range(2, ws.max_row + 1)
            for idx in rows:
                awb = ws.cell(row=idx, column=1).value
                if not awb: continue

                mfcode = get_api_response(awb)
                if mfcode == "N/A":
                    update_output_text(output_text, f"{awb} 未找到MFCODE\n")
                    continue

                p_hist = get_post_history(mfcode)
                q_hist = get_qty_history(mfcode)
                t_amnt = get_all_amount(mfcode)

                res = generate_manifest_summary(p_hist, q_hist, t_amnt)

                ws.cell(row=idx, column=2).value = mfcode
                ws.cell(row=idx, column=3).value = awb
                # 填充 D(4) E(5) F(6) G(7) H(8) I(9)
                for i, val in enumerate(res, 4):
                    ws.cell(row=idx, column=i).value = val

                update_output_text(output_text, f'{awb} 成功\n')

            wb.save(file_path)
            update_output_text(output_text, "处理完成\n")
        except Exception as e:
            update_output_text(output_text, f"错误: {e}\n")

    main_function()


