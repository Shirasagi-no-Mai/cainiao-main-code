    def _format_time_from_ms(ms_value, tz_str=None):
        try:
            seconds = ms_value / 1000.0
            dt_utc = datetime.utcfromtimestamp(seconds)
            dt_local = dt_utc
            if tz_str and isinstance(tz_str, str):
                tz_clean = tz_str.strip()
                m = re.match(r"^(?:UTC)?([+-])(\d{2}):(\d{2})$", tz_clean)
                if m:
                    sign = 1 if m.group(1) == "+" else -1
                    offset = timedelta(hours=int(m.group(2)), minutes=int(m.group(3)))
                    dt_local = dt_utc + sign * offset
            return dt_local.strftime("%Y-%m-%d %H:%M:%S")
        except:
            return "N/A"

