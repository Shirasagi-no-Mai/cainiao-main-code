                "MAWB": info.get("MAWB", "N/A"),
                "口岸": "LAX", "月份": "",
                "ETA": info.get("ETA", "N/A"),
                "CTN": info.get("NUMBER OF CTN", "N/A"),
                "PARCELS": info.get("QUANTITY OF PARCELS", "N/A"),
                "weight": info.get("GROSS WEIGHT", "N/A"),
                # 修正：Key 名与 extract_flight_info 里的标准名一致
                "COE weight": info.get("COE/UP_WEIGHT", "N/A"),
                "DHL weight": info.get("DHL_WEIGHT", "N/A"),
                "SPX weight": info.get("SPX_WEIGHT", "N/A"),
                "usps weight": info.get("USPS_WEIGHT", "N/A"),
                "fedex weight": info.get("FEDEX_WEIGHT", "N/A"),
            }
            for ch in channel_order:
                flat_info[f"{ch}_CTN"] = info.get(f"{ch}_CTN", "N/A")

            results.append(flat_info)
            processed_count += 1
            update_output_text(output_text, f"已处理 {processed_count} 个邮件\n")

    # 表头与写入
    header_fixed = ["MAWB", "口岸", "月份", "ETA", "CTN", "PARCELS", "weight", "COE weight", "DHL weight", "SPX weight",
                    "usps weight","fedex weight"]
    header_channels = [f"{ch}_CTN" for ch in channel_order]
    header_keys = header_fixed + header_channels

    df = pd.DataFrame(results, columns=header_keys)

    # 向上取整逻辑
    for col in df.columns:
        if col.endswith("_CTN"):
            divisor = 10 if "USPS" in col else 20
            df[col] = df[col].apply(lambda x: x if x == "N/A" else -(-float(x) // divisor))

    update_output_text(output_text, "正在写入 Excel...\n")
    try:
        df.to_excel(file_path, sheet_name='预报数据', index=False)
        update_output_text(output_text, f"写入完成：{file_path}\n")
    except Exception as e:
        update_output_text(output_text, f"写入失败: {e}\n")

    update_output_text(output_text, f"所有邮件处理完成，共 {processed_count} 封。\n")

